# ─────────────────────────────────────────────────────────────────────────────
# AdFlow Pro — Environment Variables Template
#
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env to version control.
#
# For Railway deployment: add each variable in the Railway dashboard under
#   Project → Service → Variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ── Supabase ─────────────────────────────────────────────────────────────────
# SUPABASE_URL — your project URL, e.g. https://xxxx.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# SUPABASE_KEY — use the SERVICE ROLE (secret) key, NOT the anon/publishable key.
# The backend bypasses RLS for admin operations, which requires the service key.
# Found in: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_KEY=your-supabase-service-role-secret-key

# ── Client (Next.js — public, safe to expose) ─────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_APP_NAME=AdFlow Pro
